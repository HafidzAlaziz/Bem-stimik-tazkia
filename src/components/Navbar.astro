---
// Navbar.astro
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1) || ''; // '' for root, 'tentang' for /tentang
const isHome = currentPath === '';
const navClasses = "fixed top-0 w-full z-50 transition-all duration-300 ease-in-out bg-transparent border-b border-transparent" + (!isHome ? " is-subpage" : "");
---
<nav class={navClasses} id="navbar">
  <div class="flex justify-between items-center h-24 px-container-padding-mobile md:px-container-padding-desktop max-w-7xl mx-auto">
    <a href="/" class="flex items-center gap-4 group">
      <img alt="BEM STMIK Tazkia Logo" class="h-14 md:h-16 object-contain group-hover:scale-105 transition-transform" src="/logo.png" />
      <div class="flex flex-col sm:block hidden">
        <span class="font-bold leading-none text-xl nav-logo-text-1">BEM STMIK</span>
        <span class="font-bold leading-none text-xl nav-logo-text-2">Tazkia</span>
      </div>
    </a>
    <!-- Desktop Nav -->
    <div class="hidden md:flex space-x-8 items-center font-label-md text-label-md">
      <a class={`nav-link desktop-nav-link relative after:absolute after:bottom-[-4px] after:left-0 after:h-1 after:bg-primary transition-all after:transition-all after:duration-300 ${currentPath === '' ? 'font-bold text-primary after:w-full after:bg-secondary after:rounded-full' : 'after:w-0 hover:after:w-full hover:text-primary'}`} href="/">Beranda</a>
      <a class={`nav-link desktop-nav-link relative after:absolute after:bottom-[-4px] after:left-0 after:h-1 after:bg-primary transition-all after:transition-all after:duration-300 ${currentPath === 'tentang' ? 'font-bold text-primary after:w-full after:bg-secondary after:rounded-full' : 'after:w-0 hover:after:w-full hover:text-primary'}`} href="/tentang">Tentang</a>
      <a class={`nav-link desktop-nav-link relative after:absolute after:bottom-[-4px] after:left-0 after:h-1 after:bg-primary transition-all after:transition-all after:duration-300 ${currentPath === 'divisi' ? 'font-bold text-primary after:w-full after:bg-secondary after:rounded-full' : 'after:w-0 hover:after:w-full hover:text-primary'}`} href="/divisi">Divisi</a>
      <a class={`nav-link desktop-nav-link relative after:absolute after:bottom-[-4px] after:left-0 after:h-1 after:bg-primary transition-all after:transition-all after:duration-300 ${currentPath === 'agenda' ? 'font-bold text-primary after:w-full after:bg-secondary after:rounded-full' : 'after:w-0 hover:after:w-full hover:text-primary'}`} href="/agenda">Agenda</a>
      <a class="nav-link desktop-nav-link relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 hover:after:w-full after:h-1 after:bg-primary hover:text-primary transition-all after:transition-all after:duration-300" href="/#saran">Saran/Aduan</a>
      <a href="/login" class="ml-4 px-8 py-3 rounded-button font-label-md transition-all cursor-pointer nav-btn shadow-soft hover:-translate-y-0.5 inline-block text-center">Masuk</a>
    </div>
    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden p-2 rounded-full cursor-pointer nav-mobile-btn transition-colors">
      <span class="material-symbols-outlined">menu</span>
    </button>
  </div>
  
  <!-- Mobile Menu Drawer (Hidden by default) -->
  <div id="mobile-menu" class="hidden md:hidden bg-surface border-b border-outline-variant/30 px-container-padding-mobile py-4 flex-col gap-4 shadow-lg absolute w-full left-0 top-full">
    <a class={`mobile-nav-link block ${currentPath === '' ? 'text-primary font-bold' : 'text-on-surface-variant'}`} href="/">Beranda</a>
    <a class={`mobile-nav-link block ${currentPath === 'tentang' ? 'text-primary font-bold' : 'text-on-surface-variant'}`} href="/tentang">Tentang</a>
    <a class={`mobile-nav-link block ${currentPath === 'divisi' ? 'text-primary font-bold' : 'text-on-surface-variant'}`} href="/divisi">Divisi</a>
    <a class={`mobile-nav-link block ${currentPath === 'agenda' ? 'text-primary font-bold' : 'text-on-surface-variant'}`} href="/agenda">Agenda</a>
    <a class="mobile-nav-link block text-on-surface-variant" href="/#saran">Saran/Aduan</a>
    <a href="/login" class="w-full bg-primary text-on-primary px-4 py-3 rounded-button font-label-md mt-2 text-center inline-block">Masuk</a>
  </div>
</nav>

<style>
  /* Base state (transparent, at top) */
  .nav-logo-text-1, 
  .nav-link,
  .nav-logo-svg {
    color: white;
    transition: color 0.3s;
  }
  .nav-logo-text-2 {
    color: white;
    transition: color 0.3s;
  }
  
  .nav-btn {
    background-color: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    color: white;
    transition: all 0.3s;
  }
  .nav-btn:hover {
    background-color: var(--color-secondary);
    border-color: var(--color-secondary);
  }

  .nav-mobile-btn {
    color: white;
    background-color: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  /* Subpage overrides for transparent state so text is readable on white backgrounds */
  nav.is-subpage:not(.is-scrolled) .nav-logo-text-1,
  nav.is-subpage:not(.is-scrolled) .nav-logo-svg {
    color: var(--color-primary);
  }
  nav.is-subpage:not(.is-scrolled) .nav-logo-text-2 {
    color: var(--color-secondary);
  }
  nav.is-subpage:not(.is-scrolled) .nav-link {
    color: var(--color-on-surface-variant);
  }
  nav.is-subpage:not(.is-scrolled) .nav-link:hover {
    color: var(--color-primary);
  }
  nav.is-subpage:not(.is-scrolled) .nav-btn {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    border-color: transparent;
  }
  nav.is-subpage:not(.is-scrolled) .nav-btn:hover {
    background-color: rgba(27, 64, 134, 0.9);
  }
  nav.is-subpage:not(.is-scrolled) .nav-mobile-btn {
    color: var(--color-primary);
    background-color: transparent;
    border: 1px solid var(--color-outline-variant);
  }

  /* Scrolled state */
  #navbar.is-scrolled .nav-logo-text-1,
  #navbar.is-scrolled .nav-logo-svg {
    color: var(--color-primary);
  }
  #navbar.is-scrolled .nav-logo-text-2 {
    color: var(--color-secondary);
  }
  #navbar.is-scrolled .nav-link {
    color: var(--color-on-surface-variant);
  }
  #navbar.is-scrolled .nav-link:hover {
    color: var(--color-primary);
  }
  #navbar.is-scrolled .nav-btn {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    border-color: transparent;
  }
  #navbar.is-scrolled .nav-btn:hover {
    background-color: rgba(27, 64, 134, 0.9);
  }
  #navbar.is-scrolled .nav-mobile-btn {
    color: var(--color-primary);
    background-color: var(--color-surface-container-low);
    border-color: transparent;
  }
</style>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.remove('bg-transparent', 'border-transparent');
      navbar?.classList.add('bg-white', 'border-outline-variant/50', 'shadow-md', 'is-scrolled');
    } else {
      navbar?.classList.add('bg-transparent', 'border-transparent');
      navbar?.classList.remove('bg-white', 'border-outline-variant/50', 'shadow-md', 'is-scrolled');
    }
  });

  // Simple logic for mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = btn?.querySelector('.material-symbols-outlined');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
    if (icon) {
      icon.textContent = menu?.classList.contains('hidden') ? 'menu' : 'close';
    }
  });

  // Dynamic Active Link Logic
  function updateActiveLinks() {
    const hash = window.location.hash;
    const pathname = window.location.pathname;
    
    // Desktop Links
    const desktopLinks = document.querySelectorAll('.desktop-nav-link');
    desktopLinks.forEach(link => {
      const href = link.getAttribute('href');
      
      // Reset classes
      link.classList.remove('font-bold', 'text-primary', 'after:w-full', 'after:bg-secondary', 'after:rounded-full');
      link.classList.add('after:w-0', 'hover:after:w-full', 'hover:text-primary');
      
      if (!href) return;

      let isActive = false;
      if (hash && href.includes('#')) {
        isActive = href.endsWith(hash);
      } else if (!hash && href === '/' && (pathname === '/' || pathname === '/index.html')) {
        isActive = true;
      } else if (!hash && href !== '/' && pathname.startsWith(href) && !href.includes('#')) {
        isActive = true;
      }

      if (isActive) {
        link.classList.add('font-bold', 'text-primary', 'after:w-full', 'after:bg-secondary', 'after:rounded-full');
        link.classList.remove('after:w-0', 'hover:after:w-full', 'hover:text-primary');
      }
    });

    // Mobile Links
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');
    mobileLinks.forEach(link => {
      const href = link.getAttribute('href');
      
      // Reset classes
      link.classList.remove('text-primary', 'font-bold');
      link.classList.add('text-on-surface-variant');
      
      if (!href) return;

      let isActive = false;
      if (hash && href.includes('#')) {
        isActive = href.endsWith(hash);
      } else if (!hash && href === '/' && (pathname === '/' || pathname === '/index.html')) {
        isActive = true;
      } else if (!hash && href !== '/' && pathname.startsWith(href) && !href.includes('#')) {
        isActive = true;
      }

      if (isActive) {
        link.classList.add('text-primary', 'font-bold');
        link.classList.remove('text-on-surface-variant');
      }
    });
  }

  // Run on load and hash change
  window.addEventListener('hashchange', updateActiveLinks);
  window.addEventListener('DOMContentLoaded', updateActiveLinks);
  
  // Intercept clicks to ensure immediate UI update
  document.querySelectorAll('.desktop-nav-link, .mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      setTimeout(updateActiveLinks, 10); // Small delay to let URL update
      
      // Close mobile menu if open
      if (menu && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        menu.classList.remove('flex');
        if (icon) icon.textContent = 'menu';
      }
    });
  });
</script>
