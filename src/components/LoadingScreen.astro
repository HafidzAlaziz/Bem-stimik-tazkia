---
// src/components/LoadingScreen.astro
import LoadingIndicator from './LoadingIndicator.astro';
import AnimatedLogo from './AnimatedLogo.astro';
---

<script is:inline>
  // Cek apakah user sudah melihat loading dan bukan sedang me-refresh (F5) halaman
  const isNavigating = performance.getEntriesByType("navigation")[0]?.type;
  const isReload = isNavigating === "reload" || (performance.navigation && performance.navigation.type === 1);
  const hasSeen = sessionStorage.getItem('hasSeenLoading');
  
  if (hasSeen && !isReload) {
    // Sembunyikan seketika sebelum halaman dirender untuk menghindari kedipan (flash)
    document.documentElement.classList.add('skip-loader');
  } else {
    sessionStorage.setItem('hasSeenLoading', 'true');
  }
</script>

<style>
  html.skip-loader #page-loader {
    display: none !important;
  }
</style>

<div id="page-loader" class="fixed inset-0 z-[100] flex flex-col items-center justify-center bg-white dark:bg-[#001235] transition-all duration-700">
  <div class="flex flex-col items-center gap-6 animate-init-fade-up">
    <!-- Lottie Animation Player -->
    <script is:inline src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
    <div class="relative flex items-center justify-center mb-4">
      <lottie-player 
        id="lottie-logo"
        src="/lottie-logo.json" 
        background="transparent" 
        speed="1" 
        style="width: 150px; height: 150px;" 
        autoplay>
      </lottie-player>
    </div>
    
    <!-- Dots animation component -->
    <div class="mt-2">
      <LoadingIndicator />
    </div>
  </div>
</div>

<script>
  // Hide loading screen after the page finishes loading
  window.addEventListener('load', () => {
    if (document.documentElement.classList.contains('skip-loader')) return;

    const loader = document.getElementById('page-loader');
    const lottiePlayer = document.getElementById('lottie-logo');
    
    if (loader && lottiePlayer) {
      // Sembunyikan layar persis ketika animasi lottie memancarkan event 'complete' (selesai 1 putaran)
      lottiePlayer.addEventListener('complete', () => {
        loader.style.opacity = '0';
        loader.style.transform = 'scale(1.05)';
        setTimeout(() => {
          loader.style.display = 'none';
        }, 700); 
      });

      // Fallback jaga-jaga kalau lottie gagal termuat
      setTimeout(() => {
        if (loader.style.display !== 'none') {
          loader.style.opacity = '0';
          setTimeout(() => { loader.style.display = 'none'; }, 700);
        }
      }, 3000);
    }
  });
</script>
