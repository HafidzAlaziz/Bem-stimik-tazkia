---
// Footer.astro
---

<footer class="w-full pt-20 pb-8 bg-primary text-white">
  <div
    class="px-container-padding-mobile md:px-container-padding-desktop max-w-7xl mx-auto flex flex-col gap-12"
  >
    <!-- Subscription Banner -->
    <div class="w-full bg-white/10 border border-white/10 rounded-3xl p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-8 animate-on-scroll animate-fade-up shadow-lg relative overflow-hidden">
      <!-- Decorative -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-secondary/20 rounded-full blur-3xl -z-10 translate-x-1/2 -translate-y-1/2"></div>
      
      <div class="flex-1 relative z-10">
        <h3 class="font-headline-md text-2xl md:text-3xl text-white font-bold mb-2">Jangan Ketinggalan Informasi!</h3>
        <p class="text-white/80 font-body-md max-w-lg">Dapatkan notifikasi kegiatan terbaru BEM STMIK Tazkia secara eksklusif langsung ke WhatsApp Anda.</p>
      </div>
      
      <div class="relative w-full md:w-auto">
        <!-- Floating Chat Bubble -->
        <div class="absolute -top-12 right-2 md:right-4 bg-white text-primary px-3 py-1.5 rounded-xl text-xs font-bold shadow-lg bubble-animate pointer-events-none z-20 flex items-center gap-1.5 border border-primary/10">
          <span class="text-[16px]">😁</span>
          Bukan Bayar yah
          <!-- Triangle pointer -->
          <div class="absolute -bottom-1.5 right-6 w-3 h-3 bg-white border-b border-r border-primary/10 rotate-45 rounded-sm"></div>
        </div>

        <form class="w-full md:w-auto flex flex-col sm:flex-row gap-3 relative z-10" onsubmit="event.preventDefault(); alert('Berhasil Berlangganan! Anda akan menerima notifikasi kegiatan BEM STMIK Tazkia via WhatsApp.'); this.reset();">
          <input type="tel" required placeholder="Nomor WhatsApp (Cth: 0812...)" class="w-full sm:w-72 md:w-80 px-5 py-3.5 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:border-secondary focus:bg-white/20 focus:ring-1 focus:ring-secondary transition-all">
          <button type="submit" class="group bg-secondary text-white font-bold py-3.5 px-6 rounded-xl hover:bg-secondary/90 hover:-translate-y-0.5 hover:shadow-[0_0_20px_rgba(242,121,30,0.5)] transition-all duration-300 flex items-center justify-center gap-2 whitespace-nowrap">
            <span class="material-symbols-outlined text-[20px] group-hover:animate-ring origin-top">notifications_active</span>
            Berlangganan
          </button>
        </form>
      </div>
    </div>

    <!-- Main Footer Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <div
        class="md:col-span-5 flex flex-col gap-6 animate-on-scroll animate-fade-up"
      >
      <div class="flex items-center gap-4 w-fit">
        <img
          alt="BEM STMIK Tazkia Logo"
          class="h-12 w-12 object-contain bg-white rounded-lg p-1.5 shadow-sm"
          src="/logo.png"
        />
        <div class="flex flex-col">
          <span class="font-bold leading-none text-xl text-white">BEM STMIK</span>
          <span class="font-bold leading-none text-xl text-secondary">Tazkia</span>
        </div>
      </div>
      <p class="text-white/80 font-body-md max-w-sm leading-relaxed">
        Badan Eksekutif Mahasiswa STMIK Tazkia Bogor. Satu langkah untuk STMIK
        Tazkia berdampak.
      </p>
    </div>

    <div
      class="md:col-span-4 flex flex-col gap-6 animate-on-scroll animate-fade-up delay-100"
    >
      <h4 class="font-headline-sm text-lg text-white font-bold tracking-wide">
        Layanan BEM
      </h4>
      <div class="flex flex-col gap-4 text-white/80 font-body-md">
        <a
          class="flex items-start gap-3 text-white/80 hover:text-white hover:-translate-y-0.5 hover:drop-shadow-[0_0_15px_rgba(255,255,255,0.5)] transition-all duration-300"
          href="#"
        >
          <span class="material-symbols-outlined text-[20px] shrink-0 mt-0.5"
            >location_on</span
          >
          <span class=""
            >Jl. Ir. H. Juanda No. 78,<br />Bogor, Jawa Barat 16122</span
          >
        </a>
        <a
          class="flex items-center gap-3 text-white/80 hover:text-white hover:-translate-y-0.5 hover:drop-shadow-[0_0_15px_rgba(255,255,255,0.5)] transition-all duration-300"
          href="mailto:bem@stis.ac.id"
        >
          <span class="material-symbols-outlined text-[20px] shrink-0"
            >mail</span
          >
          bem@stis.ac.id
        </a>
      </div>
    </div>

    <div
      class="md:col-span-3 flex flex-col gap-6 animate-on-scroll animate-fade-up delay-200"
    >
      <h4 class="font-headline-sm text-lg text-white font-bold tracking-wide">
        Sosial Media
      </h4>
      <div class="flex gap-4 text-white/80 mt-2">
        <a class="hover:text-[#E1306C] hover:-translate-y-2 hover:scale-110 hover:drop-shadow-[0_0_15px_rgba(225,48,108,0.6)] transition-all duration-300" href="#" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
        <a class="hover:text-[#1DA1F2] hover:-translate-y-2 hover:scale-110 hover:drop-shadow-[0_0_15px_rgba(29,161,242,0.6)] transition-all duration-300" href="#" aria-label="Twitter">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
        </a>
        <a class="hover:text-[#0077b5] hover:-translate-y-2 hover:scale-110 hover:drop-shadow-[0_0_15px_rgba(0,119,181,0.6)] transition-all duration-300" href="#" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a class="hover:text-[#FF0000] hover:-translate-y-2 hover:scale-110 hover:drop-shadow-[0_0_15px_rgba(255,0,0,0.6)] transition-all duration-300" href="#" aria-label="YouTube">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
        </a>
      </div>
    </div>

    <div
      class="col-span-1 md:col-span-12 border-t border-white/10 mt-8 pt-8 text-center text-white/50 font-caption text-sm"
    >
      © 2024 BEM STMIK Tazkia. All Rights Reserved.
    </div>
  </div>
</footer>

<style>
  @keyframes ring {
    0% { transform: rotate(0); }
    15% { transform: rotate(15deg); }
    30% { transform: rotate(-15deg); }
    45% { transform: rotate(10deg); }
    60% { transform: rotate(-10deg); }
    75% { transform: rotate(5deg); }
    85% { transform: rotate(-5deg); }
    100% { transform: rotate(0); }
  }
  .animate-ring {
    animation: ring 0.5s ease-in-out;
  }
  
  @keyframes bubble-pop {
    0%, 100% { opacity: 0; transform: translateY(10px) scale(0.9); }
    10%, 60% { opacity: 1; transform: translateY(0) scale(1); }
    70% { opacity: 0; transform: translateY(-5px) scale(0.95); }
  }
  .bubble-animate {
    animation: bubble-pop 5s infinite ease-in-out;
    transform-origin: bottom center;
  }
</style>
